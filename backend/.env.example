PORT=3000
CLIENT_ORIGIN=http://127.0.0.1:5500

# Local fallback database. This starts immediately after npm install.
DB_DIALECT=sqlite
DB_STORAGE=dev.sqlite

# PostgreSQL mode for deployment or local Postgres.
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=flora_db
# DB_USER=postgres
# DB_PASSWORD=postgres

# Hosted PostgreSQL, for example Render. If set, it overrides DB_DIALECT.
# DATABASE_URL=postgres://user:password@host:5432/database?sslmode=require
